# ── Backend ──────────────────────────────────────────────────────────────────
# Copy this file to backend/.env and fill in the values for local development.
# For production (Render), set these as environment variables in the dashboard.

# Server
NODE_ENV=development
PORT=3001

# PostgreSQL
# Local dev: matches docker-compose.yml credentials
# Production: copy Internal Database URL from Render dashboard
DATABASE_URL=postgresql://leaderboard:leaderboard_secret@localhost:5432/leaderboard

# Redis
# Local dev: matches docker-compose.yml
# Production: copy Internal Redis URL from Render dashboard
REDIS_URL=redis://localhost:6379

# MongoDB (optional — analytics/audit trail only, can be left empty locally)
# Local dev: matches docker-compose.yml credentials
# Production: use MongoDB Atlas connection string
MONGODB_URI=mongodb://leaderboard:leaderboard_secret@localhost:27017/leaderboard?authSource=admin

# Auth
# Local dev: any string works
# Production: generate a random 64-char string
JWT_SECRET=change-this-to-a-long-random-secret-in-production
ADMIN_SECRET=change-this-admin-secret-too

# CORS — URL of your frontend
# Local dev:
FRONTEND_URL=http://localhost:5173
# Production: FRONTEND_URL=https://your-app.onrender.com

# Cron — weekly prize distribution job
# Keep false in local dev, set to true in production
ENABLE_CRON=false

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Local dev: leave these empty — Vite proxies /api and /ws to localhost:3001
# Production: set to your deployed backend URLs
VITE_API_URL=https://your-backend.onrender.com/api
VITE_WS_URL=wss://your-backend.onrender.com/ws